{
	"extends": "@repo/typescript-config/base.json",
	"compilerOptions": {
		"module": "nodenext",
		"moduleResolution": "nodenext",

		"target": "ES2023",
		"strict": true,
		"esModuleInterop": true,
		"types": ["node"],
		"skipLibCheck": true,
		"outDir": "./dist",
		"declaration": true,
		"declarationMap": true
	}
}